# Configuração para upload_to_vm.py — copie para .env.publish e preencha.
# .env.publish é gitignored (não versionar credenciais/IP).
VM_HOST=200.100.50.1
VM_USER=ubuntu
VM_SSH_PORT=22
VM_RELEASES_DIR=/var/www/sparta-updates
# Se o usuário SSH não é o dono de /var/www, precisa de sudo sem senha:
#   sudo visudo  →  ubuntu ALL=(ALL) NOPASSWD: /bin/mv, /bin/mkdir, /bin/chown
VM_SUDO=1
NOTAS=Release com torch CUDA bundled e ativação automática por hardware.
